    "candidates": {
      "items": {
        "$ref": "#/$defs/candidate"
      },
      "maxItems": 49,
      "minItems": 49,
      "type": "array",
      "uniqueItems": true
    },
    "contract": {
      "additionalProperties": false,
      "properties": {
        "blockers": {
          "items": {
            "enum": [
              "copyright-attribution-review-pending",
              "distribution-closure-unproven",
              "license-expression-review-pending",
              "license-text-coverage-pending",
              "native-and-base-image-transitive-inventory-pending",
              "notice-text-coverage-pending",
              "qt-pyside-lgpl-compliance-decision-pending",
              "source-offer-and-relinking-obligations-pending"
            ]
          },
          "maxItems": 8,
          "minItems": 8,
          "type": "array",
          "uniqueItems": true
        },
        "candidate_count": {
          "const": 49
        },
        "compliance_status": {
          "const": "pending-lic-01"
        },
        "id": {
          "const": "LIC-01A"
        },
        "legal_approval": {
          "const": false
        },
        "notice_bundle_complete": {
          "const": false
        },
        "observed_target_count": {
          "const": 3
        },
        "public_distribution_authorized": {
          "const": false
        },
        "purpose": {
          "const": "deterministic inventory coverage contract; not legal approval"
        },
        "qt_pyside_lgpl_decision": {
          "const": "pending"
        },
        "target_cell_count": {
          "const": 12
        }
      },
      "required": [
        "blockers",
        "candidate_count",
        "compliance_status",
        "id",
        "legal_approval",
        "notice_bundle_complete",
        "observed_target_count",
        "public_distribution_authorized",
        "purpose",
        "qt_pyside_lgpl_decision",
        "target_cell_count"
      ],
      "type": "object"
    },
    "coverage": {
      "additionalProperties": false,
      "properties": {
        "added_observation_rows": {
          "items": {
            "$ref": "#/$defs/globalTransformRecord"
          },
          "maxItems": 1,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "applicable_lock_candidate_union_count": {
          "const": 48
        },
        "distribution_closure": {
          "const": "unproven"
        },
        "distribution_surface_inventory": {
          "const": "enumerated-not-license-reviewed"
        },
        "excluded_applicable_lock_candidates": {
          "items": {
            "$ref": "#/$defs/globalTransformRecord"
          },
          "maxItems": 1,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "license_observation_scope": {
          "const": "python-package-input-only"
        },
        "lock_candidate_count": {
          "const": 49
        },
        "not_applicable_to_observed_targets": {
          "items": {
            "$ref": "#/$defs/notApplicableRecord"
          },
          "maxItems": 1,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "observation_row_union_count": {
          "const": 48
        },
        "observed_locked_candidate_union_count": {
          "const": 47
        },
        "observed_target_count": {
          "const": 3
        },
        "observed_target_ids": {
          "items": {
            "enum": [
              "cpython-3.11-darwin-arm64",
              "cpython-3.11-linux-x86_64",
              "cpython-3.11-win32-amd64"
            ]
          },
          "maxItems": 3,
          "minItems": 3,
          "type": "array",
          "uniqueItems": true
        },
        "unobserved_target_count": {
          "const": 9
        },
        "unobserved_target_ids": {
          "items": {
            "enum": [
              "cpython-3.10-darwin-arm64",
              "cpython-3.10-darwin-x86_64",
              "cpython-3.10-linux-x86_64",
              "cpython-3.10-win32-amd64",
              "cpython-3.11-darwin-x86_64",
              "cpython-3.12-darwin-arm64",
              "cpython-3.12-darwin-x86_64",
              "cpython-3.12-linux-x86_64",
              "cpython-3.12-win32-amd64"
            ]
          },
          "maxItems": 9,
          "minItems": 9,
          "type": "array",
          "uniqueItems": true
        }
