        "reason": {
          "enum": [
            "editable-project-target-addition",
            "explicit-target-scoped-scanner-exclusion"
          ]
        },
        "target_ids": {
          "items": {
            "enum": [
              "cpython-3.11-darwin-arm64",
              "cpython-3.11-linux-x86_64",
              "cpython-3.11-win32-amd64"
            ]
          },
          "maxItems": 3,
          "minItems": 3,
          "type": "array",
          "uniqueItems": true
        },
        "version": {
          "enum": [
            "0.1.0",
            "83.0.0"
          ]
        }
      },
      "required": [
        "name",
        "reason",
        "target_ids",
        "version"
      ],
      "type": "object"
    },
    "identifiedSpdxLicense": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "pattern": "^[A-Za-z0-9._/,\\[\\]-]+$",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size": {
          "minimum": 1,
          "type": "integer"
        },
        "spdx": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "path",
        "sha256",
        "size",
        "spdx"
      ],
      "type": "object"
    },
    "identifiedSurfaceFile": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "path": {
          "pattern": "^[A-Za-z0-9._/,\\[\\]-]+$",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
