    "notApplicableRecord": {
      "additionalProperties": false,
      "properties": {
        "applicable_target_ids": {
          "items": {
            "enum": [
              "cpython-3.10-darwin-arm64",
              "cpython-3.10-darwin-x86_64",
              "cpython-3.10-linux-x86_64",
              "cpython-3.10-win32-amd64"
            ]
          },
          "maxItems": 4,
          "minItems": 4,
          "type": "array",
          "uniqueItems": true
        },
        "name": {
          "const": "exceptiongroup"
        },
        "reason": {
          "const": "marker-not-applicable-to-observed-targets"
        },
        "version": {
          "const": "1.3.1"
        }
      },
      "required": [
