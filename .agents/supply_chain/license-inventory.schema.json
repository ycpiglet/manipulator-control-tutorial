        "name",
        "reason",
        "version"
      ],
      "type": "object"
    },
    "observedPackage": {
      "additionalProperties": false,
      "properties": {
        "license_observation": {
          "anyOf": [
            {
              "maxLength": 1048576,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "license_text_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "type": "string"
        },
        "notice_text_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "url_observation": {
          "anyOf": [
            {
              "maxLength": 4096,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "license_observation",
        "license_text_sha256",
        "name",
        "notice_text_sha256",
        "url_observation",
        "version"
      ],
      "type": "object"
    },
    "observedTarget": {
      "additionalProperties": false,
      "properties": {
        "added_observation_rows": {
          "items": {
            "$ref": "#/$defs/targetTransformRecord"
          },
          "maxItems": 1,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "applicable_lock_candidate_count": {
          "maximum": 48,
          "minimum": 43,
          "type": "integer"
        },
        "artifact": {
          "$ref": "#/$defs/artifact"
        },
        "cell_id": {
          "pattern": "^cpython-3\\.11-(linux-x86_64|win32-amd64|darwin-arm64)$",
          "type": "string"
        },
        "excluded_applicable_lock_candidates": {
          "items": {
            "$ref": "#/$defs/targetTransformRecord"
          },
          "maxItems": 1,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "id": {
          "pattern": "^github-hosted-(linux|windows|macos)-cpython-3\\.11$",
          "type": "string"
        },
        "metadata_gaps": {
          "$ref": "#/$defs/gapCounts"
        },
        "observation_row_count": {
          "maximum": 48,
          "minimum": 43,
          "type": "integer"
        },
        "observed_locked_candidate_count": {
          "maximum": 47,
          "minimum": 42,
          "type": "integer"
        },
        "package_count": {
          "maximum": 48,
          "minimum": 43,
          "type": "integer"
        },
        "package_observations": {
          "items": {
            "$ref": "#/$defs/observedPackage"
          },
          "maxItems": 48,
          "minItems": 43,
          "type": "array",
          "uniqueItems": true
        },
        "recorded_target": {
          "$ref": "#/$defs/recordedTarget"
        },
        "runner_os": {
          "enum": [
            "Linux",
            "Windows",
            "macOS"
          ]
        }
      },
      "required": [
        "added_observation_rows",
        "applicable_lock_candidate_count",
        "artifact",
        "cell_id",
        "excluded_applicable_lock_candidates",
        "id",
        "metadata_gaps",
        "observation_row_count",
        "observed_locked_candidate_count",
        "package_count",
        "package_observations",
        "recorded_target",
        "runner_os"
      ],
      "type": "object"
    },
