{
  "$defs": {
    "archiveKeyring": {
      "additionalProperties": false,
      "properties": {
        "package": {
          "const": "ubuntu-keyring"
        },
        "path": {
          "const": "/usr/share/keyrings/ubuntu-archive-keyring.gpg"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "size": {
          "minimum": 1,
          "type": "integer"
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "package",
        "path",
        "sha256",
        "size",
        "version"
      ],
      "type": "object"
    },
    "artifact": {
      "additionalProperties": false,
      "properties": {
        "canonical_evidence_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "expires_at": {
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
          "type": "string"
        },
        "id": {
          "minimum": 1,
          "type": "integer"
        },
        "name": {
          "pattern": "^mclab-supply-chain-(Linux|Windows|macOS)$",
          "type": "string"
        },
        "normalization_algorithm": {
          "const": "strict-json-sort-keys-indent-2-ensure-ascii-false-utf8-lf"
        },
        "normalization_version": {
          "const": 1
        },
        "raw_evidence_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "canonical_evidence_sha256",
        "expires_at",
        "id",
        "name",
        "normalization_algorithm",
        "normalization_version",
        "raw_evidence_sha256"
      ],
      "type": "object"
    },
    "candidate": {
      "additionalProperties": false,
      "properties": {
        "environment_ids": {
          "items": {
            "pattern": "^cpython-3\\.(10|11|12)-(linux-x86_64|win32-amd64|darwin-(arm64|x86_64))$",
            "type": "string"
          },
          "maxItems": 12,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "marker": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "type": "string"
        },
        "review_status": {
          "const": "pending"
        },
        "version": {
          "maxLength": 128,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "environment_ids",
        "marker",
        "name",
        "review_status",
        "version"
      ],
      "type": "object"
    },
    "dataGroup": {
      "additionalProperties": false,
      "properties": {
        "destination": {
          "minLength": 1,
          "type": "string"
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "license_ids": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 1,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "source": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "destination",
        "id",
        "license_ids",
        "source"
      ],
      "type": "object"
    },
    "gapCounts": {
      "additionalProperties": false,
      "properties": {
        "license": {
          "maximum": 48,
          "minimum": 0,
          "type": "integer"
        },
        "license_text": {
          "maximum": 48,
          "minimum": 0,
          "type": "integer"
        },
        "notice_text": {
          "maximum": 48,
          "minimum": 0,
          "type": "integer"
        },
        "url": {
          "maximum": 48,
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "license",
        "license_text",
        "notice_text",
        "url"
      ],
      "type": "object"
    },
    "globalTransformRecord": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "enum": [
            "mujoco-manipulator-control-lab",
            "setuptools"
          ]
